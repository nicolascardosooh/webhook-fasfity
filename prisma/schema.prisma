// prisma/schema.prisma - Banco de Dados Unificado (SaaS Core + Fórum + Gestão)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider     = "postgresql"
  url          = env("DATABASE_URL")
  relationMode = "prisma"
}

// ==========================================
// NÚCLEO (CORE) E MULTI-TENANCY
// ==========================================

model Company {
  id        String   @id @default(uuid())
  name      String
  cnpj      String?  @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Configurações de Banco de Dados Dinâmico
  databaseName String? @unique
  databaseHost String? @default("localhost")
  databasePort Int?    @default(5432)
  databaseUser String? @default("postgres")
  databasePass String?

  // Identificação externa e Branding
  externalId String? @unique
  logoUrl    String?
  logoFile   Bytes?

  // Relações
  users         User[]
  subscriptions Subscription[]
  events        Event[]
  clientes      Cliente[]

  // Relações Fórum
  forumCategories ForumCategory[]
  forumTopics     ForumTopic[]
  forumPosts      ForumPost[]
}

model User {
  id                String   @id @default(uuid())
  name              String
  email             String   @unique
  password          String
  passwordResetCode String?
  role              String   @default("USER")
  active            Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Multi-tenancy
  companyId    String
  company      Company @relation(fields: [companyId], references: [id])
  profileId    String?
  externalId   String? @unique
  sessionToken String?

  // Relações Fórum
  forumTopics        ForumTopic[]
  forumPosts         ForumPost[]
  forumLikes         ForumLike[]
  forumNotifications ForumNotification[]

  @@index([companyId])
}

// ==========================================
// FÓRUM (COMUNIDADE)
// ==========================================

model ForumCategory {
  id          String   @id @default(uuid())
  name        String
  description String?
  slug        String   @unique
  order       Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  companyId String
  company   Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  topics    ForumTopic[]

  @@index([companyId])
}

model ForumTopic {
  id        String   @id @default(uuid())
  title     String
  content   String   @db.Text
  views     Int      @default(0)
  isSolved  Boolean  @default(false)
  isLocked  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  categoryId String
  category   ForumCategory @relation(fields: [categoryId], references: [id])
  authorId   String
  author     User          @relation(fields: [authorId], references: [id])
  companyId  String
  company    Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)

  posts         ForumPost[]
  likes         ForumLike[]
  notifications ForumNotification[]

  @@index([categoryId])
  @@index([authorId])
  @@index([companyId])
}

model ForumPost {
  id         String   @id @default(uuid())
  content    String   @db.Text
  isSolution Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  topicId   String
  topic     ForumTopic @relation(fields: [topicId], references: [id], onDelete: Cascade)
  authorId  String
  author    User       @relation(fields: [authorId], references: [id])
  companyId String
  company   Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)

  likes         ForumLike[]
  notifications ForumNotification[]

  @@index([topicId])
  @@index([authorId])
  @@index([companyId])
}

model ForumLike {
  id        String      @id @default(uuid())
  userId    String
  user      User        @relation(fields: [userId], references: [id])
  topicId   String?
  topic     ForumTopic? @relation(fields: [topicId], references: [id], onDelete: Cascade)
  postId    String?
  post      ForumPost?  @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt DateTime    @default(now())

  @@unique([userId, topicId])
  @@unique([userId, postId])
  @@index([userId])
  @@index([topicId])
  @@index([postId])
}

model ForumNotification {
  id      String      @id @default(uuid())
  userId  String
  user    User        @relation(fields: [userId], references: [id])
  topicId String?
  topic   ForumTopic? @relation(fields: [topicId], references: [id], onDelete: Cascade)
  postId  String?
  post    ForumPost?  @relation(fields: [postId], references: [id], onDelete: Cascade)

  title     String?
  message   String?
  link      String?
  type      String // 'REPLY', 'SOLUTION', 'MENTION', 'SYSTEM'
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([read])
  @@index([topicId])
  @@index([postId])
}

// ==========================================
// ASSINATURAS E FINANCEIRO (SAAS)
// ==========================================

model Plan {
  id            String   @id @default(uuid())
  key           PlanKey  @unique
  name          String
  priceCents    Int
  usersIncluded Int      @default(1)
  nfseLimit     Int?
  features      Json
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  subscriptions Subscription[]
}

enum PlanKey {
  gratuito
  basico
  intermediario
  avancado
}

model Subscription {
  id        String             @id @default(uuid())
  status    SubscriptionStatus @default(pending)
  active    Boolean            @default(false)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  companyId  String
  company    Company @relation(fields: [companyId], references: [id])
  planId     String
  plan       Plan    @relation(fields: [planId], references: [id])
  moduleKeys String[] // Módulos contratados a parte (keys)

  nextDueDate DateTime?
  invoices    Invoice[]
  payments    Payment[]

  @@index([companyId])
  @@index([planId])
}

enum SubscriptionStatus {
  pending
  active
  canceled
  past_due
  trialing
}

model Invoice {
  id             String        @id @default(uuid())
  status         InvoiceStatus @default(pending)
  amountCents    Int
  dueDate        DateTime
  paidAt         DateTime?
  pdfUrl         String?
  externalId     String? // ID na EFI/Pagar.me
  subscriptionId String
  subscription   Subscription  @relation(fields: [subscriptionId], references: [id])
  payments       Payment[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([subscriptionId])
}

enum InvoiceStatus {
  pending
  paid
  canceled
  refunded
  overdue
}

model Payment {
  id             String        @id @default(uuid())
  amountCents    Int
  method         PaymentMethod
  status         PaymentStatus @default(pending)
  gatewayRef     String? // ID da transação no gateway
  gatewayPayload Json? // Payload retornado pelo gateway
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  invoiceId      String
  invoice        Invoice      @relation(fields: [invoiceId], references: [id])
  subscriptionId String
  subscription   Subscription @relation(fields: [subscriptionId], references: [id])

  @@index([invoiceId])
  @@index([subscriptionId])
}

enum PaymentMethod {
  credit_card
  boleto
  pix
}

enum PaymentStatus {
  pending
  authorized
  captured
  failed
  canceled
  refunded
}

// ==========================================
// GESTÃO DE MÓDULOS (SAAS)
// ==========================================

model Management {
  id          String   @id @default(uuid())
  name        String
  key         String   @unique
  description String?
  priceCents  Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ==========================================
// RASTREAMENTO E ANALYTICS
// ==========================================

model Event {
  id        String   @id @default(uuid())
  type      String
  payload   Json?
  createdAt DateTime @default(now())

  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])

  @@index([companyId])
}

// ==========================================
// ÁREA DO CLIENTE (PORTAL)
// ==========================================

model Cliente {
  id        String   @id @default(uuid())
  name      String
  email     String
  document  String? // CPF/CNPJ
  password  String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  companyId String
  company   Company @relation(fields: [companyId], references: [id])

  @@unique([companyId, email])
  @@index([companyId])
}
